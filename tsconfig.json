{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "strict": true,
    "types": ["svelte"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "forge.env.d.ts"
  ],
  "exclude": ["node_modules", "out", "dist", ".vite"]
}
