{
  "name": "risotron-studio",
  "productName": "RisoTron Studio",
  "version": "1.8.0",
  "description": "AI-powered creative studio platform",
  "main": ".vite/build/main.js",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "keywords": [],
  "author": "binn",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "42.2.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.1.1",
    "svelte-check": "^4.4.8",
    "typescript": "~5.5.0",
    "vite": "^5.4.21",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "electron-squirrel-startup": "^1.0.1",
    "svelte": "^5.55.9"
  }
}
